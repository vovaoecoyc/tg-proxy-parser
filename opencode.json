{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "enabled_providers": [
    "llama",
    "trueconf",
    "openrouter"
  ],
  "plugin": ["superpowers@git+https://github.com/obra/superpowers.git"],
  "model": "trueconf/pro",
  "small_model": "trueconf/fast",
  "share": "disabled",
  "lsp": true,
  "formatter": true,
  "permission": {
    "edit": {
      "*": "ask",
      "tasks-descriptions/**": "allow"
    },
    "read": {
      "*": "allow",
      "*.env": "deny"
    },
    "skill": {
      "api-code-formatter": "deny"
    },
    "external_directory": "ask"
  },
  "agent": {
    "build": {
      "permission": {
        "edit": {
          "*": "ask",
          "src/**": "allow"
        }
      }
    }
  },
  "watcher": {
    "ignore": [
      "node_modules/**",
      "dist/**",
      ".git/**",
      ".turbo/**"
    ]
  },
  "provider": {
    "trueconf": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "TRUECONF 🔒",
      "options": {
        "baseURL": "https://llm.trueconf.com/v1"
      },
      "models": {
        "pro": {
          "name": "Pro",
          "limit": { "context": 150000, "output": 32768 },
          "tool_call": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        },
        "fast": {
          "name": "Fast",
          "limit": { "context": 175000, "output": 16384 },
          "tool_call": true,
          "attachment": true,
          "modalities": { "input": ["text", "image"], "output": ["text"] }
        }
      }
    }
  },
  "mcp": {
    "searxng": {
      "type": "remote",
      "url": "http://10.110.0.61:8889/mcp",
      "enabled": true
    },
    "context7": {
      "type": "remote",
      "url": "http://10.110.0.61:8890/mcp",
      "enabled": true
    }
  }
}